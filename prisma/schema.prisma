datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  priority    String
  dueDate     String   // YYYY-MM-DD
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}